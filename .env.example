# Email (Resend) - for contact form and blog subscriptions
RESEND_API_KEY=

# Blog subscription
RESEND_SEGMENT_ID=         # Resend Segment ID for subscribers
SUBSCRIBE_HMAC_SECRET=     # 32-byte random secret: openssl rand -base64 32
